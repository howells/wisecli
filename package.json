{
  "name": "@howells/wisecli",
  "version": "0.2.0",
  "description": "CLI for Wise — balances, transfers, profiles. Agent-first: structured JSON output, multi-token, schema introspection.",
  "type": "module",
  "license": "MIT",
  "author": "Daniel Howells <daniel.howells@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/howells/wisecli"
  },
  "homepage": "https://github.com/howells/wisecli#readme",
  "keywords": [
    "wise",
    "transferwise",
    "cli",
    "finance",
    "agent",
    "ai"
  ],
  "os": [
    "darwin",
    "linux"
  ],
  "bin": {
    "wisecli": "./dist/index.js",
    "wisecli-mcp": "./dist/mcp-server.js"
  },
  "files": [
    "dist",
    "AGENTS.md",
    "CLAUDE.md",
    "llms.txt",
    "llms-full.txt",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "mcp": "tsx src/mcp-server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "howells-lint",
    "format": "howells-format",
    "gen:llms": "(echo '<!-- Generated: README.md + AGENTS.md concatenated for token-bounded ingestion. Regenerate with: pnpm gen:llms -->'; echo; cat README.md; echo; echo '---'; echo; cat AGENTS.md) > llms-full.txt",
    "prepublishOnly": "pnpm build",
    "prepare": "howells-husky"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,jsonc,css}": "howells-format"
  },
  "devDependencies": {
    "@howells/husky": "^0.1.0",
    "@howells/lint": "^0.1.3",
    "@howells/typescript-config": "^0.1.2",
    "@types/node": "^22.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@howells/cli": "^0.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  }
}
